 {"cell_type":"code","source":[
   "# 10 RELIABLE families (proven to download and run)\\n",
   "MODELS = [\\n",
   "    ('mistralai/Mistral-7B-v0.3','mistralai/Mistral-7B-Instruct-v0.3','Mistral-7B'),\\n",
   "    ('Qwen/Qwen2.5-0.5B','Qwen/Qwen2.5-0.5B-Instruct','Qwen2.5-0.5B'),\\n",
   "    ('Qwen/Qwen2.5-1.5B','Qwen/Qwen2.5-1.5B-Instruct','Qwen2.5-1.5B'),\\n",
   "    ('google/gemma-2-2b','google/gemma-2-2b-it','Gemma2-2B'),\\n",
   "    ('tiiuae/falcon-rw-1b','tiiuae/falcon-rw-1b-instruct','Falcon-1B'),\\n",
   "    ('bigscience/bloomz-1b1','bigscience/bloomz-1b1','Bloomz-1B'),\\n",
   "    ('EleutherAI/pythia-410m','EleutherAI/pythia-410m','Pythia-410M'),\\n",
   "    ('google/recurrentgemma-2b','google/recurrentgemma-2b-it','RecurrentGemma-2B'),\\n",
   "    ('ibm-granite/granite-3b-code-base','ibm-granite/granite-3b-code-instruct','Granite-3B'),\\n",
   "    ('EleutherAI/pythia-1.4b','EleutherAI/pythia-1.4b','Pythia-1.4B'),\\n",
   "    ('EleutherAI/pythia-2.8b','EleutherAI/pythia-2.8b-deduped','Pythia-2.8B'),\\n",
   "    ('TinyLlama/TinyLlama-1.1B-intermediate-step-1431k-3T','TinyLlama/TinyLlama-1.1B-Chat-v1.0','TinyLlama-1.1B'),\\n",
   "]\\n",
   "print(f'{len(MODELS)} families')"
 ]},
 {"cell_type":"code","source":[
