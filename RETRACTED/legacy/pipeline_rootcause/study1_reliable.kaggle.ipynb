 {"cell_type":"code","source":[
   "# Probes + parsers + ALL variables\\n",
   "PROBES = {\\n",
   "    'rubric_order': {'normal':'Score 1-5 (1=worst).','reversed':'Score 1-5 (1=best).','random':'Scale: 3=A,5=B,1=C,2=D,4=E.'},\\n",
   "    'score_id': {'numeric':'Score 1-5.','letter':'Score A-E (A=best).','descriptive':'Score: Poor, Fair, Good, V.Good, Excellent.'},\\n",
   "    'reference_answer': {'no_ref':'Score 1-5.','good_ref':'Good example: AI improves via training.\\nNow score 1-5.','poor_ref':'Poor example: idk lol.\\nNow score 1-5.'},\\n",
   "}\\n",
   "PROBES_TO_RUN = [('rubric_order',['normal','reversed','random']),('score_id',['numeric','letter','descriptive']),('reference_answer',['no_ref','good_ref','poor_ref'])]\\n",
   "REPEATS=3\\n",
   "CKPT='/kaggle/working/ckpt.json'\\n",
   "OUT='/kaggle/working/results.json'\\n",
   "def bp(p,v,i): return f'{PROBES[p][v]}\\n### Instruction:\\n{i[\"instr\"]}\\n### Response:\\n{i[\"resp\"]}\\n### Score:'\\n",
   "def es(t): import re; m=re.search(r'\\b([1-5])\\b',t); return int(m.group(1)) if m else 3\\n",
   "def el(t): import re; m=re.search(r'\\b([A-E])\\b',t.upper()); return {'A':5,'B':4,'C':3,'D':2,'E':1}.get(m.group(1),3) if m else 3\\n",
   "def ed(t):\\n",
   "    t=t.lower().strip()\\n",
   "    if 'excellent' in t: return 5\\n",
   "    for w,s in [('very good',4),('good',4),('fair',3),('poor',2),('terrible',1),('bad',1)]:\\n",
   "        if w in t: return s\\n",
   "    return es(t)\\n",
   "def gs(p,v): return ed if p=='score_id' and v=='descriptive' else el if p=='score_id' and v=='letter' else es\\n",
   "print('ready')"
 ]},
 {"cell_type":"code","source":[
   "# MAIN LOOP  fully hardened\\n",
   "all_results = {}\\n",
   "completed = set()\\n",
   "if os.path.exists(CKPT):\\n",
   "    with open(CKPT) as f: cp=json.load(f)\\n",
   "    all_results=cp.get('results',{}); completed=set(cp.get('completed',[]))\\n",
   "    print(f'Resumed {len(completed)} families')\\n",
   "\\n",
   "def gen_score(model,tok,prompt,scorer):\\n",
   "    '''Thread-safe generation with hard timeout.'''\\n",
   "    result=[None]; done=[]\\n",
   "    def work():\\n",
   "        try:\\n",
   "            inp=tok(prompt,return_tensors='pt',truncation=True,max_length=1024).to(model.device)\\n",
   "            with torch.no_grad():\\n",
   "                out=model.generate(**inp,max_new_tokens=5,temperature=0.0,do_sample=False,pad_token_id=tok.pad_token_id)\\n",
   "            result[0]=scorer(tok.decode(out[0][inp['input_ids'].shape[1]:],skip_special_tokens=True))\\n",
   "        except: pass\\n",
   "        done.append(True)\\n",
   "    t=threading.Thread(target=work,daemon=True)\\n",
   "    t.start(); t.join(timeout=10)\\n",
   "    return result[0] if done else 3\\n",
   "\\n",
   "for idx,(b_id,i_id,name) in enumerate(MODELS):\\n",
   "    if name in completed:\\n",
   "        continue\\n",
   "    for vt,vn in [('base',b_id),('instruct',i_id)]:\\n",
   "        fn=f'{name}_{vt}'\\n",
   "        print(f'[{len(completed)+1}/{len(MODELS)}] {fn} ',end='',flush=True)\\n",
   "        t0=time.time()\\n",
   "        try:\\n",
   "            tok=AutoTokenizer.from_pretrained(vn,trust_remote_code=True)\\n",
   "            if tok.pad_token is None: tok.pad_token=tok.eos_token\\n",
   "            m=AutoModelForCausalLM.from_pretrained(vn,torch_dtype=torch.float16,device_map='auto',trust_remote_code=True,low_cpu_mem_usage=True)\\n",
   "            m.eval()\\n",
   "        except Exception as e:\\n",
   "            print(f'FAIL {str(e)[:50]}'); all_results[fn]={'error':str(e)[:100]}; continue\\n",
   "        res={}\\n",
   "        for pt,pvs in PROBES_TO_RUN:\\n",
   "            res[pt]={}\\n",
   "            for pn in pvs:\\n",
   "                scr=gs(pt,pn); scores=[]\\n",
   "                for rep in range(REPEATS):\\n",
   "                    r=[]\\n",
   "                    for it in ITEMS:\\n",
   "                        r.append(gen_score(m,tok,bp(pt,pn,it),scr))\\n",
   "                    scores.append(r)\\n",
   "                res[pt][pn]=scores\\n",
   "                total=sum(len(x) for x in scores)\\n",
   "                avg=sum(sum(x) for x in scores)/total if total>0 else 0\\n",
   "                print(f'{pn[:3]}={avg:.1f} ',end='',flush=True)\\n",
   "        all_results[fn]=res\\n",
   "        del m,tok; gc.collect(); torch.cuda.empty_cache()\\n",
   "    completed.add(name)\\n",
   "    with open(CKPT,'w') as f: json.dump({'results':all_results,'completed':list(completed)},f)\\n",
   "    print(f'OK ({time.time()-t0:.0f}s)')\\n",
   "\\n",
   "with open(OUT,'w') as f: json.dump(all_results,f)\\n",
   "print(f'DONE. {OUT}')"
 ]},
 {"cell_type":"code","source":[
   "# Summary\\n",
   "print('\\n'+'='*60)\\n",
   "for mn,r in sorted(all_results.items()):\\n",
   "    if 'error' in r: print(f'{mn:<25} FAILED'); continue\\n",
   "    bs={}\\n",
   "    for pt,pvs in PROBES_TO_RUN:\\n",
   "        vm=[]\\n",
   "        for pn in pvs:\\n",
   "            if pt in r and pn in r[pt] and len(r[pt][pn])>0:\\n",
   "                s=sum(sum(x) for x in r[pt][pn])/max(sum(len(x) for x in r[pt][pn]),1)\\n",
   "                vm.append(s)\\n",
   "        if len(vm)>1: bs[pt]=max(abs(vm[i]-vm[0]) for i in range(len(vm)))\\n",
   "    rub=bs.get('rubric_order',-1); sco=bs.get('score_id',-1); ref=bs.get('reference_answer',-1)\\n",
   "    avg=sum(v for v in [rub,sco,ref] if v>=0)/max(sum(1 for v in [rub,sco,ref] if v>=0),1)\\n",
   "    print(f'{mn:<25} Rub={rub:<6.2f} Sco={sco:<6.2f} Ref={ref:<6.2f} Avg={avg:.2f}')\\n",
   "print('='*60)\\n",
   "print(f'OK: {len([m for m in all_results if \"error\" not in m])}/{len(all_results)}')"
 ]}
]
