  "scores": {
    "metadata": {
      "description": "Per-model per-probe per-variant mean scores across 50 evaluation items (3 repeats each, greedily decoded). Score scale: 1-5.",
      "source_files": ["results_rootcause/study1_results.json", "results_rootcause/t4fam_results.json"],
      "probe_definitions": {
        "rubric_order": {
          "description": "Tests whether rubric label direction affects scores",
          "control": "normal (1=worst, 5=best)",
          "variants": {
            "normal": "Standard rubric: 1=worst to 5=best",
            "reversed": "Reversed rubric: 1=best to 5=worst",
            "random": "Random label mapping"
          }
        },
        "score_id": {
          "description": "Tests whether score label format affects scores",
          "control": "numeric (1-5)",
          "variants": {
            "numeric": "Numeric labels: 1-5",
            "letter": "Letter grades: A-E (converted to 1-5)",
            "descriptive": "Descriptive labels: Poor-Excellent (mapped to 1-5)"
          }
        },
        "reference_answer": {
          "description": "Tests whether exemplar responses bias subsequent scoring",
          "control": "no_ref (no exemplar provided)",
          "variants": {
            "no_ref": "No reference answer provided (control)",
            "good_ref": "High-quality exemplar shown before scoring",
            "poor_ref": "Low-quality exemplar shown before scoring"
          }
        }
      }
    },
    "models": {}
  },
  "bias_metrics": {
    "metadata": {
      "description": "Bias metrics computed from perturbation probes. Each metric captures a different aspect of scoring bias.",
      "metrics_definitions": {
        "max_delta": "Maximum absolute difference between any two variant means for a probe. Higher = more biased.",
        "flip_rate": "Proportion of items where the biased condition score differs from the control condition score. Range [0, 1].",
        "cohens_d": "Standardized effect size: (biased_mean - control_mean) / pooled_std. Standard interpretation: 0.2=small, 0.5=medium, 0.8=large.",
        "mean_abs_bias": "Mean absolute deviation across all variants. Captures overall bias magnitude regardless of direction."
      },
      "source_files": [
        "results_rootcause/analysis_output/t4fam_deltas.json",
        "results_rootcause/analysis_output/cohens_d.json",
        "results_rootcause/analysis_output/robustness_metrics.json"
      ]
    },
    "t4fam_deltas": {
      "description": "Per-model max delta per probe for the 7 T4-evaluated base-instruct families (14 models). Delta = max variant mean - min variant mean.",
      "models": {}
    },
    "study1_deltas": {
      "description": "Per-model max delta per probe for the 22 instruct-only models.",
      "models": {}
    },
