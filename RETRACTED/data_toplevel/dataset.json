{
  "metadata": {
    "dataset_name": "Scoring Bias in LLM-as-a-Judge  Unified Dataset",
    "version": "1.0.0",
    "description": "Complete experimental dataset for scoring bias analysis in LLM-as-a-Judge models. Contains per-model per-probe scores, bias deltas, flip rates, and metadata for 31 model variants across 16 families.",
    "total_judgments": 40500,
    "total_models": 31,
    "model_variants": {"base": 9, "instruct": 22},
    "base_instruct_paired_families": 11,
    "probe_types": ["rubric_order", "score_id", "reference_answer"],
    "probe_variants_per_type": 3,
    "score_scale": "1-5 (integer)",
    "items": 80,
    "domains": ["science", "technology", "humanities", "daily_life", "mathematics"],
    "items_per_domain": {"primary": 10, "total_set": 80},
    "repeats_per_condition": 3,
    "decoding": "greedy (temperature=0)",
    "total_api_cost_usd": 3.0,
    "inference_platforms": ["Kaggle T4 GPU", "OpenRouter API", "Local CPU"],
    "citation": "Samba, S. (2026). Scoring Bias in LLM-as-a-Judge Models. arXiv preprint. doi:10.5281/zenodo.21361920"
  },
