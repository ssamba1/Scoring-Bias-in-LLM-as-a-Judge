  {"cell_type":"markdown","source":["# Reproduce: Scoring Bias Analysis\n\nOpen this in Colab → Runtime → Run all. No GPU needed. Results in 5 minutes."]},
  {"cell_type":"code","source":["!pip install matplotlib numpy pandas openai -q\nfrom openai import OpenAI\nimport json, time, os, re\n\nopenai.api_key='your_openrouter_key'\nopenai.base_url='https://openrouter.ai/api/v1'\n\nprint('Ready')"]},
  {"cell_type":"code","source":["# Quick demo: test 3 models on 5 items\nMODELS=[('meta-llama/llama-3.1-8b-instruct','Llama'),('google/gemma-4-31b-it:free','Gemma'),('openai/gpt-oss-20b:free','GPT-OSS')]\nITEMS=[{'instr':'Explain gravity.','resp':'Mass attracts mass.'}]\n\ndef score(mid,item):\n    r=openai.chat.completions.create(model=mid,messages=[{'role':'user','content':f'Score 1-5.\\n### Instruction:\\n{item[\"instr\"]}\\n### Response:\\n{item[\"resp\"]}\\n### Score:'}],max_tokens=5,temperature=0,timeout=10)\n    return r.choices[0].message.content.strip()\n\nfor mid,nm in MODELS:\n    print(f'{nm}: {score(mid,ITEMS[0])}')\nprint('Demo complete. Full experiment takes ~2-4 hours.')"]},
