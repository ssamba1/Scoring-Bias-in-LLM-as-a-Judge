    "resp": "\u092a\u093e\u0928\u0940 \u092e\u0939\u093e\u0938\u093e\u0917\u0930\u094b\u0902 \u0938\u0947 \u0935\u093e\u0937\u094d\u092a\u093f\u0924 \u0939\u094b\u0924\u093e \u0939\u0948, \u092c\u093e\u0926\u0932 \u092c\u0928\u093e\u0924\u093e \u0939\u0948, \u0914\u0930 \u0935\u0930\u094d\u0937\u093e \u0915\u0947 \u0930\u0942\u092a \u092e\u0947\u0902 \u0932\u094c\u091f\u0924\u093e \u0939\u0948\u0964",
    "en_instr": "Describe the water cycle.",
    "item_id": 42
  },
  {
    "instr": "\u092d\u0942\u0915\u0902\u092a \u0915\u093e \u0915\u093e\u0930\u0923 \u0915\u094d\u092f\u093e \u0939\u0948?",
    "resp": "\u091f\u0947\u0915\u094d\u091f\u094b\u0928\u093f\u0915 \u092a\u094d\u0932\u0947\u091f\u0947\u0902 \u0926\u094b\u0937 \u0930\u0947\u0916\u093e\u0913\u0902 \u0915\u0947 \u0938\u093e\u0925 \u0916\u093f\u0938\u0915\u0924\u0940 \u0939\u0948\u0902, \u092d\u0942\u0915\u0902\u092a\u0940\u092f \u0924\u0930\u0902\u0917\u094b\u0902 \u0915\u0947 \u0930\u0942\u092a \u092e\u0947\u0902 \u090a\u0930\u094d\u091c\u093e \u091b\u094b\u0921\u093c\u0924\u0940 \u0939\u0948\u0902\u0964",
    "en_instr": "What causes earthquakes?",
    "item_id": 43
  },
  {
    "instr": "\u091f\u0940\u0915\u0947 \u0915\u0948\u0938\u0947 \u0915\u093e\u092e \u0915\u0930\u0924\u0947 \u0939\u0948\u0902 \u0938\u092e\u091d\u093e\u090f\u0902\u0964",
    "resp": "\u091f\u0940\u0915\u0947 \u0939\u093e\u0928\u093f\u0930\u0939\u093f\u0924 \u090f\u0902\u091f\u0940\u091c\u0928 \u092a\u0947\u0936 \u0915\u0930\u0915\u0947 \u092a\u094d\u0930\u0924\u093f\u0930\u0915\u094d\u0937\u093e \u092a\u094d\u0930\u0923\u093e\u0932\u0940 \u0915\u094b \u0930\u094b\u0917\u091c\u0928\u0915\u094b\u0902 \u0915\u094b \u092a\u0939\u091a\u093e\u0928\u0928\u0947 \u0915\u0947 \u0932\u093f\u090f \u092a\u094d\u0930\u0936\u093f\u0915\u094d\u0937\u093f\u0924 \u0915\u0930\u0924\u0947 \u0939\u0948\u0902\u0964",
    "en_instr": "Explain how vaccines work.",
    "item_id": 44
  },
  {
    "instr": "\u0921\u0940\u090f\u0928\u090f \u0915\u094d\u092f\u093e \u0939\u0948?",
    "resp": "\u0921\u0940\u090f\u0928\u090f \u0935\u0943\u0926\u094d\u0927\u093f, \u0935\u093f\u0915\u093e\u0938 \u0914\u0930 \u092a\u094d\u0930\u091c\u0928\u0928 \u0915\u0947 \u0932\u093f\u090f \u0906\u0928\u0941\u0935\u0902\u0936\u093f\u0915 \u0928\u093f\u0930\u094d\u0926\u0947\u0936 \u0930\u0916\u0924\u093e \u0939\u0948\u0964",
