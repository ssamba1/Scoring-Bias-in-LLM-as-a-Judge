    "resp": "\u0930\u093e\u0938\u093e\u092f\u0928\u093f\u0915 \u0905\u092d\u093f\u0915\u094d\u0930\u093f\u092f\u093e\u090f\u0902 \u0907\u0932\u0947\u0915\u094d\u091f\u094d\u0930\u094b\u0921 \u0915\u0947 \u092c\u0940\u091a \u0907\u0932\u0947\u0915\u094d\u091f\u094d\u0930\u094b\u0932\u093e\u0907\u091f \u0915\u0947 \u092e\u093e\u0927\u094d\u092f\u092e \u0938\u0947 \u0907\u0932\u0947\u0915\u094d\u091f\u094d\u0930\u0949\u0928 \u092a\u094d\u0930\u0935\u093e\u0939 \u092c\u0928\u093e\u0924\u0940 \u0939\u0948\u0902\u0964",
