    "item_id": 45
  },
  {
    "instr": "\u0938\u094c\u0930 \u092e\u0902\u0921\u0932 \u0915\u093e \u0935\u0930\u094d\u0923\u0928 \u0915\u0930\u0947\u0902\u0964",
    "resp": "\u0938\u094c\u0930 \u092e\u0902\u0921\u0932 \u092e\u0947\u0902 \u0938\u0942\u0930\u094d\u092f \u0915\u0940 \u092a\u0930\u093f\u0915\u094d\u0930\u092e\u093e \u0915\u0930\u0928\u0947 \u0935\u093e\u0932\u0947 8 \u0917\u094d\u0930\u0939 \u0939\u0948\u0902\u0964",
