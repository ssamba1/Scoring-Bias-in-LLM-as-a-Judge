 {"cell_type":"code","source":[
   "!pip install -q transformers torch huggingface_hub numpy scipy\\n",
   "import torch, gc, os, json, re, time, threading\\n",
   "from transformers import AutoModelForCausalLM, AutoTokenizer\\n",
   "from huggingface_hub import login\\n",
   "import getpass\\n",
   "token = getpass.getpass('HF token: ')\\n",
   "login(token=token)\\n",
   "os.environ['HF_TOKEN'] = token\\n",
   "print('Ready')"
 ]},
 {"cell_type":"code","source":[
   "# 10 TINY models (all under 3B, download in <30s)\\n",
   "MODELS = [\\n",
   "    ('Qwen/Qwen2.5-0.5B', 'Qwen/Qwen2.5-0.5B-Instruct', 'Qwen-0.5B'),\\n",
   "    ('Qwen/Qwen2.5-1.5B', 'Qwen/Qwen2.5-1.5B-Instruct', 'Qwen-1.5B'),\\n",
   "    ('google/gemma-2-2b', 'google/gemma-2-2b-it', 'Gemma2-2B'),\\n",
   "    ('google/gemma-2b', 'google/gemma-2b-it', 'Gemma1-2B'),\\n",
   "    ('google/recurrentgemma-2b', 'google/recurrentgemma-2b-it', 'RecurrentGemma-2B'),\\n",
   "    ('microsoft/Phi-3-mini-4k-instruct', 'microsoft/Phi-3-mini-4k-instruct', 'Phi3-mini'),\\n",
   "    ('tiiuae/falcon-rw-1b', 'tiiuae/falcon-rw-1b-instruct', 'Falcon-1B'),\\n",
   "    ('bigscience/bloomz-1b1', 'bigscience/bloomz-1b1', 'Bloomz-1B'),\\n",
   "    ('EleutherAI/pythia-410m', 'EleutherAI/pythia-410m', 'Pythia-410M'),\\n",
   "    ('EleutherAI/pythia-1.4b', 'EleutherAI/pythia-1.4b', 'Pythia-1.4B'),\\n",
   "    ('EleutherAI/pythia-2.8b', 'EleutherAI/pythia-2.8b-deduped', 'Pythia-2.8B'),\\n",
   "    ('TinyLlama/TinyLlama-1.1B-intermediate-step-1431k-3T', 'TinyLlama/TinyLlama-1.1B-Chat-v1.0', 'TinyLlama-1.1B'),\\n",
   "    ('ibm-granite/granite-3b-code-base', 'ibm-granite/granite-3b-code-instruct', 'Granite-3B'),\\n",
   "    ('bigcode/starcoder2-3b', 'bigcode/starcoder2-3b', 'StarCoder-3B'),\\n",
   "]\\n",
   "print(f'{len(MODELS)} small models')"
 ]},
 {"cell_type":"code","source":[
   "ITEMS = [{'instr':'Explain how photosynthesis works.','resp':'Plants convert CO2+water to glucose+oxygen using sunlight.'},{'instr':'What is relativity?','resp':'Space and time are relative to observer frame.'},{'instr':'Water cycle?','resp':'Evaporation, condensation, precipitation.'},{'instr':'Earthquakes?','resp':'Tectonic plates shift along faults.'},{'instr':'Vaccines?','resp':'Train immune system with harmless antigens.'},{'instr':'What is DNA?','resp':'Genetic instructions for growth and reproduction.'},{'instr':'Solar system?','resp':'8 planets orbiting the Sun.'},{'instr':'Entropy?','resp':'Disorder measure. Always increases.'},{'instr':'Batteries?','resp':'Chemical reactions push electrons through electrolyte.'},{'instr':'Black hole?','resp':'Gravity so strong light cannot escape.'},{'instr':'ML?','resp':'AI learns patterns from data.'},{'instr':'Cloud computing?','resp':'On-demand internet computing resources.'},{'instr':'API?','resp':'Software communication interface.'},{'instr':'Encryption?','resp':'Algorithms encode data with keys.'},{'instr':'Database index?','resp':'Structure speeding up data retrieval.'},{'instr':'Python?','resp':'High-level readable programming language.'},{'instr':'Internet?','resp':'Global TCP/IP network.'},{'instr':'Blockchain?','resp':'Immutable distributed ledger.'},{'instr':'OS?','resp':'Software managing hardware for apps.'},{'instr':'Neural networks?','resp':'Computing systems like biological neurons.'},{'instr':'WW1 cause?','resp':'Archduke assassination triggered alliances.'},{'instr':'Democracy?','resp':'Citizens vote for representatives.'},{'instr':'Renaissance?','resp':'14th-17th century cultural rebirth.'},{'instr':'Capitalism?','resp':'Private ownership, profit, competition.'},{'instr':'UN?','resp':'International peace organization.'},{'instr':'Cold War?','resp':'US-USSR tension 1947-1991.'},{'instr':'Ethics?','resp':'Moral principles for right/wrong.'},{'instr':'Feudalism?','resp':'Medieval land-for-service system.'},{'instr':'Philosophy?','resp':'Study of existence, knowledge.'},{'instr':'Globalization?','resp':'Worldwide economic interconnection.'},{'instr':'Cook pasta?','resp':'Boil salted water, cook al dente.'},{'instr':'Healthy diet?','resp':'Fruits, veg, protein, whole grains.'},{'instr':'Cars?','resp':'Engine burns fuel, turns pistons.'},{'instr':'Exercise?','resp':'Warm up, strength, cardio, cool down.'},{'instr':'Sleep?','resp':'REM/non-REM 90-min cycles.'},{'instr':'Meditation?','resp':'Focus attention for mental calm.'},{'instr':'First aid?','resp':'CPR, wound cleaning, call 911.'},{'instr':'Save money?','resp':'Track expenses, budget, reduce spending.'},{'instr':'Climate change?','resp':'Greenhouse gases cause warming.'},{'instr':'Recycling?','resp':'Process waste into new products.'},{'instr':'Calculus?','resp':'Study of change via derivatives.'},{'instr':'p-value?','resp':'Probability under null hypothesis.'},{'instr':'Prime number?','resp':'Divisible only by 1 and itself.'},{'instr':'Std deviation?','resp':'Spread of numbers from mean.'},{'instr':'Logarithm?','resp':'Inverse of exponentiation.'},{'instr':'Probability?','resp':'Likelihood 0 to 1.'},{'instr':'Bayes theorem?','resp':'Probability from prior knowledge.'},{'instr':'Linear regression?','resp':'Fit line to variables.'},{'instr':'Derivative?','resp':'Rate of function change.'},{'instr':'Correlation?','resp':'Variables moving together -1 to 1.'}];print(f'{len(ITEMS)} items')"
 ]},
 {"cell_type":"code","source":[
   "PROBES = {'rubric_order':{'normal':'Score 1-5 (1=worst).','reversed':'Score 1-5 (1=best).','random':'Scale: 3=A,5=B,1=C,2=D,4=E.'},'score_id':{'numeric':'Score 1-5.','letter':'Score A-E (A=best).','descriptive':'Score: Poor, Fair, Good, V.Good, Excellent.'},'reference_answer':{'no_ref':'Score 1-5.','good_ref':'Good example: AI improves via training.\\nNow score 1-5.','poor_ref':'Poor example: idk lol.\\nNow score 1-5.'}}\\n",
   "P=[('rubric_order',['normal','reversed','random']),('score_id',['numeric','letter','descriptive']),('reference_answer',['no_ref','good_ref','poor_ref'])]\\n",
   "R=3;CK='/kaggle/working/ck.json';OT='/kaggle/working/res.json'\\n",
   "def bp(p,v,i): return f'{PROBES[p][v]}\\n### Instruction:\\n{i[\"instr\"]}\\n### Response:\\n{i[\"resp\"]}\\n### Score:'\\n",
   "def es(t): import re; m=re.search(r'\\b([1-5])\\b',t); return int(m.group(1)) if m else 3\\n",
   "def el(t): import re; m=re.search(r'\\b([A-E])\\b',t.upper()); return {'A':5,'B':4,'C':3,'D':2,'E':1}.get(m.group(1),3) if m else 3\\n",
   "def ed(t):\\n",
   "    t=t.lower().strip()\\n",
   "    if 'excellent' in t: return 5\\n",
   "    for w,s in [('very good',4),('good',4),('fair',3),('poor',2),('terrible',1),('bad',1)]:\\n",
   "        if w in t: return s\\n",
   "    return es(t)\\n",
   "def gs(p,v): return ed if p=='score_id' and v=='descriptive' else el if p=='score_id' and v=='letter' else es\\n",
   "print('ready')"
 ]},
 {"cell_type":"code","source":[
   "# MAIN LOOP  small models only, 10s timeout per generation\\n",
   "all_r={};done=set()\\n",
   "if os.path.exists(CK):\\n",
   "    with open(CK) as f: cp=json.load(f)\\n",
   "    all_r=cp.get('r',{});done=set(cp.get('d',[]));print(f'Resumed {len(done)}')\\n",
   "\\n",
   "def gs2(m,t,p,s):\\n",
   "    r=[None];d=[]\\n",
   "    def w():\\n",
   "        try:\\n",
   "            inp=t(p,return_tensors='pt',truncation=True,max_length=1024).to(m.device)\\n",
   "            with torch.no_grad(): out=m.generate(**inp,max_new_tokens=5,temperature=0.0,do_sample=False,pad_token_id=t.pad_token_id)\\n",
   "            r[0]=s(t.decode(out[0][inp['input_ids'].shape[1]:],skip_special_tokens=True))\\n",
   "        except: pass\\n",
   "        d.append(1)\\n",
   "    th=threading.Thread(target=w,daemon=True);th.start();th.join(timeout=10)\\n",
   "    return r[0] if d else 3\\n",
   "\\n",
   "for idx,(bi,ii,nm) in enumerate(MODELS):\\n",
   "    if nm in done: continue\\n",
   "    for vt,vn in [('b',bi),('i',ii)]:\\n",
   "        fn=f'{nm}_{vt}';print(f'[{len(done)+1}/{len(MODELS)}] {fn} ',end='',flush=True)\\n",
   "        t0=time.time()\\n",
   "        try:\\n",
   "            tok=AutoTokenizer.from_pretrained(vn,trust_remote_code=True)\\n",
   "            if not tok.pad_token: tok.pad_token=tok.eos_token\\n",
   "            m=AutoModelForCausalLM.from_pretrained(vn,torch_dtype=torch.float16,device_map='auto',trust_remote_code=True,low_cpu_mem_usage=True);m.eval()\\n",
   "        except Exception as e: print(f'FAIL {str(e)[:30]}');all_r[fn]={'e':str(e)[:50]};continue\\n",
   "        rs={}\\n",
   "        for pt,pv in P:\\n",
   "            rs[pt]={}\\n",
   "            for pn in pv:\\n",
   "                sc=gs(pt,pn);ss=[]\\n",
   "                for _ in range(R):\\n",
   "                    r=[gs2(m,tok,bp(pt,pn,i),sc) for i in ITEMS];ss.append(r)\\n",
   "                rs[pt][pn]=ss\\n",
   "                ttl=sum(len(x) for x in ss)\\n",
   "                av=sum(sum(x) for x in ss)/ttl if ttl else 0\\n",
   "                print(f'{pn[:3]}={av:.1f} ',end='',flush=True)\\n",
   "        all_r[fn]=rs\\n",
   "        del m,tok;gc.collect();torch.cuda.empty_cache()\\n",
   "    done.add(nm)\\n",
   "    with open(CK,'w') as f: json.dump({'r':all_r,'d':list(done)},f)\\n",
   "    print(f'=({time.time()-t0:.0f}s)')\\n",
   "\\n",
   "with open(OT,'w') as f: json.dump(all_r,f)\\n",
   "print(f'DONE. {OT}')"
 ]},
 {"cell_type":"code","source":[
   "print('\\n'+'='*60)\\n",
   "for mn,r in sorted(all_r.items()):\\n",
   "    if 'e' in r: print(f'{mn:<25} FAILED');continue\\n",
   "    bs={}\\n",
   "    for pt,pv in P:\\n",
   "        vm=[]\\n",
   "        for pn in pv:\\n",
   "            if pt in r and pn in r[pt] and len(r[pt][pn])>0:\\n",
   "                s=sum(sum(x) for x in r[pt][pn])/max(sum(len(x) for x in r[pt][pn]),1);vm.append(s)\\n",
   "        if len(vm)>1: bs[pt]=max(abs(vm[i]-vm[0]) for i in range(len(vm)))\\n",
   "    ru=bs.get('rubric_order',-1);sc=bs.get('score_id',-1);rf=bs.get('reference_answer',-1)\\n",
   "    av=sum(v for v in [ru,sc,rf] if v>=0)/max(sum(1 for v in [ru,sc,rf] if v>=0),1)\\n",
   "    print(f'{mn:<25} Ru={ru:<6.2f} Sc={sc:<6.2f} Rf={rf:<6.2f} Av={av:.2f}')\\n",
   "print('='*60)\\n",
   "print(f'OK: {len([m for m in all_r if \"e\" not in m])}/{len(all_r)}')"
 ]}
]
