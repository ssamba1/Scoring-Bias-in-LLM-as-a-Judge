 {
  "cell_type": "code",
  "metadata": {},
  "source": [
   "# ===== TIER 2 #2: ATTENTION ANALYSIS AT 8B SCALE =====\n",
   "print('Loading Llama-3.1-8B for attention analysis...')\n",
   "\n",
   "ATTN_PROMPT = \"\"\"Evaluate the following response.\n",
   "### Instruction: Explain how photosynthesis works.\n",
   "### Response: Photosynthesis happens in plants where they use sunlight to make food.\n",
   "### Score from 1-5 (where 1 is worst, 5 is best)\n",
   "### Score:\"\"\"\n",
   "\n",
   "FORMAT_PATTERNS = [\"###\", \"Instruction\", \"Response\", \"Score\", \"1\", \"2\", \"3\", \"4\", \"5\", \n",
   "                   \"from\", \"where\", \"is\", \"the\", \"worst\", \"best\", \":\", \"\\n\", \" \", \".\"]\n",
   "CONTENT_PATTERNS = [\"photosynthesis\", \"explain\", \"happens\", \"plants\", \"sunlight\", \n",
   "                    \"food\", \"make\", \"use\", \"they\", \"how\", \"works\"]\n",
   "\n",
   "def classify_tokens(token_ids, tokenizer):\n",
   "    labels = []\n",
   "    for tid in token_ids:\n",
   "        t = tokenizer.decode(tid).strip().lower()\n",
   "        if any(f in t for f in FORMAT_PATTERNS):\n",
   "            labels.append(\"FORMAT\")\n",
   "        elif any(c in t for c in CONTENT_PATTERNS):\n",
   "            labels.append(\"CONTENT\")\n",
   "        else:\n",
   "            labels.append(\"OTHER\")\n",
   "    return labels\n",
   "\n",
   "ATTN_MODELS = [\n",
   "    (\"meta-llama/Meta-Llama-3-8B\", \"Llama-3-8B-base\"),\n",
   "    (\"meta-llama/Meta-Llama-3-8B-Instruct\", \"Llama-3-8B-instruct\"),\n",
   "]\n",
   "\n",
   "attn_results = {}\n",
   "\n",
   "for model_id, name in ATTN_MODELS:\n",
   "    print(f'\\n=== Loading {name} for attention analysis ===')\n",
   "    tokenizer = AutoTokenizer.from_pretrained(model_id, token=os.environ['HF_TOKEN'])\n",
   "    model = AutoModelForCausalLM.from_pretrained(\n",
   "        model_id, torch_dtype=torch.float16, device_map='auto',\n",
   "        output_attentions=True, token=os.environ['HF_TOKEN']\n",
   "    )\n",
   "    model.eval()\n",
   "    \n",
   "    inputs = tokenizer(ATTN_PROMPT, return_tensors='pt').to(model.device)\n",
   "    labels = classify_tokens(inputs['input_ids'][0].tolist(), tokenizer)\n",
   "    \n",
   "    n_format = labels.count('FORMAT')\n",
   "    n_content = labels.count('CONTENT')\n",
   "    print(f'  Tokens: {len(labels)} total, {n_format} format, {n_content} content')\n",
   "    \n",
   "    with torch.no_grad():\n",
   "        outputs = model(**inputs, output_attentions=True)\n",
   "    \n",
   "    attentions = outputs.attentions\n",
   "    format_attn = []\n",
   "    content_attn = []\n",
   "    \n",
   "    for layer_idx, attn in enumerate(attentions):\n",
   "        avg_attn = attn[0].mean(dim=0)\n",
   "        last_token_attn = avg_attn[-1, :] * 100\n",
   "        \n",
   "        f_attn = sum(last_token_attn[i].item() for i in range(len(labels)) if labels[i] == 'FORMAT')\n",
   "        c_attn = sum(last_token_attn[i].item() for i in range(len(labels)) if labels[i] == 'CONTENT')\n",
   "        format_attn.append(f_attn)\n",
   "        content_attn.append(c_attn)\n",
   "    \n",
   "    attn_results[name] = {\n",
   "        'format_attn_per_layer': format_attn,\n",
   "        'content_attn_per_layer': content_attn,\n",
   "        'mean_format_attn': float(np.mean(format_attn)),\n",
   "        'mean_content_attn': float(np.mean(content_attn)),\n",
   "    }\n",
   "    print(f'  Mean format: {attn_results[name][\"mean_format_attn\"]:.2f}%')\n",
   "    print(f'  Mean content: {attn_results[name][\"mean_content_attn\"]:.2f}%')\n",
   "    \n",
   "    del model\n",
   "    gc.collect()\n",
   "    torch.cuda.empty_cache()\n",
   "\n",
   "# Compare\n",
   "base_a = attn_results.get('Llama-3-8B-base')\n",
   "instruct_a = attn_results.get('Llama-3-8B-instruct')\n",
   "if base_a and instruct_a:\n",
   "    k_format = instruct_a['mean_format_attn'] / max(base_a['mean_format_attn'], 0.01)\n",
   "    k_content = instruct_a['mean_content_attn'] / max(base_a['mean_content_attn'], 0.01)\n",
   "    \n",
   "    print(f'\\n{\"=\"*60}')\n",
   "    print('IIAR / FORMAT EFFICIENCY TEST AT 8B')\n",
   "    print(f'{\"=\"*60}')\n",
   "    print(f'Format κ = {k_format:.3f}x (IIAR predicts >1.0, Format Efficiency predicts <1.0)')\n",
