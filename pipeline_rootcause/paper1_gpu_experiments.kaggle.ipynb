   "# ===== SCORING FUNCTION =====\n",
   "def score_model(model, tokenizer, item, probe_type, probe_variant, device):\n",
   "    prompt = make_prompt(item, probe_type, probe_variant)\n",
   "    inputs = tokenizer(prompt, return_tensors='pt', truncation=True, max_length=1024).to(device)\n",
   "    with torch.no_grad():\n",
   "        outputs = model.generate(\n",
   "            **inputs, max_new_tokens=5, temperature=0.0,\n",
   "            do_sample=False, pad_token_id=tokenizer.eos_token_id,\n",
   "            num_return_sequences=1\n",
   "        )\n",
   "    # Extract score after prompt\n",
   "    full = tokenizer.decode(outputs[0], skip_special_tokens=True)\n",
   "    score_text = full[len(prompt):].strip()\n",
   "    # Try to extract numeric score\n",
   "    numbers = re.findall(r'[\\d.]+', score_text)\n",
   "    if numbers:\n",
   "        try:\n",
   "            return float(numbers[0])\n",
   "        except:\n",
   "            pass\n",
   "    return None\n",
   "\n",
   "\n",
   "def score_model_safe(model, tokenizer, item, probe_type, probe_variant, device, max_retries=2):\n",
   "    for attempt in range(max_retries):\n",
   "        try:\n",
   "            return score_model(model, tokenizer, item, probe_type, probe_variant, device)\n",
   "        except Exception as e:\n",
   "            if attempt == max_retries - 1:\n",
   "                return None\n",
   "            time.sleep(2)\n",
   "    return None\n",
   "\n",
   "print('Scoring functions ready')"
  ]
 },
