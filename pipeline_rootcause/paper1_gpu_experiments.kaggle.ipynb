   "# ===== NEW BASE+INSTRUCT PAIRS (families NOT in existing data) =====\\n",
   "NEW_FAMILIES = [\\n",
   "    # Open 7B+ models (needed for content bias scale validation)\\n",
   "    ('mistralai/Mistral-7B-v0.3', 'mistralai/Mistral-7B-Instruct-v0.3', 'Mistral-7B-v0.3'),\\n",
   "    ('allenai/OLMo-7B-hf', 'allenai/OLMo-7B-instruct-hf', 'OLMo-7B'),\\n",
   "    ('deepseek-ai/deepseek-llm-7b-base', 'deepseek-ai/deepseek-llm-7b-chat', 'DeepSeek-7B'),\\n",
   "    ('google/gemma-2-9b', 'google/gemma-2-9b-it', 'Gemma2-9B'),\\n",
   "    # Smaller new architectures\\n",
   "    ('google/recurrentgemma-2b', 'google/recurrentgemma-2b-it', 'RecurrentGemma-2B'),\\n",
   "    ('ibm-granite/granite-3b-code-base', 'ibm-granite/granite-3b-code-instruct', 'Granite-3B'),\\n",
   "    ('tiiuae/falcon-rw-1b', 'tiiuae/falcon-rw-1b-instruct', 'Falcon-1B'),\\n",
   "    ('TinyLlama/TinyLlama-1.1B-intermediate-step-1431k-3T', 'TinyLlama/TinyLlama-1.1B-Chat-v1.0', 'TinyLlama-1.1B'),\\n",
   "    ('allenai/OLMo-1B-hf', 'allenai/OLMo-1B-instruct-hf', 'OLMo-1B'),\\n",
   "    ('microsoft/Phi-3-mini-4k-instruct', 'microsoft/Phi-3-mini-4k-instruct', 'Phi-3-mini'),\\n",
   "]\\n",
   "print(f'{len(NEW_FAMILIES)} new families to run')\\n"
  ]
 },
 {
  "cell_type": "code",
  "metadata": null,
  "source": [
   "# ===== SCORING FUNCTION =====\\n",
   "def score_model(model, tokenizer, prompt, device):\\n",
   "    inputs = tokenizer(prompt, return_tensors='pt', truncation=True, max_length=1024).to(device)\\n",
   "    with torch.no_grad():\\n",
   "        outputs = model.generate(**inputs, max_new_tokens=5, temperature=0.0,\\n",
   "            do_sample=False, pad_token_id=tokenizer.eos_token_id, num_return_sequences=1)\\n",
   "    full = tokenizer.decode(outputs[0], skip_special_tokens=True)\\n",
   "    score_text = full[len(prompt):].strip()\\n",
   "    numbers = re.findall(r'[\\d.]+', score_text)\\n",
   "    if numbers:\\n",
   "        try: return float(numbers[0])\\n",
   "        except: pass\\n",
   "    return None\\n",
   "print('Scoring function ready')\\n"
  ]
 },
 {
  "cell_type": "code",
  "metadata": null,
  "source": [
   "# ===== RUN TIER 2: collect bias data for all NEW families =====\\n",
   "print(f'Starting run for {len(NEW_FAMILIES)} families on {torch.cuda.get_device_name(0)}')\\n",
   "all_results = {}\\n",
   "device = torch.device('cuda')\\n",
   "\\n",
   "for base_id, instruct_id, name in NEW_FAMILIES:\\n",
   "    for variant_suffix, model_id in [('', base_id), ('-IT', instruct_id)]:\\n",
   "        model_name = f'{name}{variant_suffix}'\\n",
   "        print(f'\\n{\"=\"*60}\\nLoading {model_name} ({model_id})\\n{\"=\"*60}')\\n",
   "        try:\\n",
   "            load_kwargs = {'torch_dtype': torch.float16, 'device_map': 'auto'}\\n",
   "            if any(s in model_id for s in ['9b', '9B', '7b', '7B', '8b', '8B']):\\n",
   "                from transformers import BitsAndBytesConfig\\n",
   "                load_kwargs['quantization_config'] = BitsAndBytesConfig(load_in_4bit=True)\\n",
   "            tokenizer = AutoTokenizer.from_pretrained(model_id, token=os.environ['HF_TOKEN'])\\n",
   "            if tokenizer.pad_token is None: tokenizer.pad_token = tokenizer.eos_token\\n",
   "            model = AutoModelForCausalLM.from_pretrained(model_id, **load_kwargs, token=os.environ['HF_TOKEN'])\\n",
   "            model.eval()\\n",
   "            print(f'  Loaded: {sum(p.numel() for p in model.parameters())/1e6:.0f}M params')\\n",
   "        except Exception as e:\\n",
   "            print(f'  FAILED to load {model_id}: {e}')\\n",
   "            continue\\n",
   "\\n",
   "        scores = {'rubric_order': {}, 'score_id': {}, 'reference_answer': {}}\\n",
   "        for probe_type, probe_variants in PROBE_VARIANTS.items():\\n",
   "            for probe_variant in probe_variants:\\n",
   "                item_scores = []\\n",
   "                for idx, item in enumerate(ITEMS):\\n",
   "                    reps = []\\n",
   "                    for _ in range(3):\\n",
   "                        prompt = make_prompt(item, probe_type, probe_variant)\\n",
   "                        try:\\n",
   "                            s = score_model(model, tokenizer, prompt, device)\\n",
   "                            if s is not None: reps.append(s)\\n",
   "                        except: pass\\n",
   "                    if reps: item_scores.append(np.mean(reps))\\n",
   "                    if (idx + 1) % 25 == 0:\\n",
   "                        print(f'  {model_name} {probe_type}/{probe_variant}: {idx+1}/{len(ITEMS)}', flush=True)\\n",
   "                scores[probe_type][probe_variant] = {\\n",
   "                    'mean': float(np.mean(item_scores)) if item_scores else None,\\n",
   "                    'std': float(np.std(item_scores)) if item_scores else None,\\n",
   "                }\\n",
   "\\n",
   "        # Compute bias delta per probe\\n",
   "        result = {}\\n",
   "        for probe_type, pv in PROBE_VARIANTS.items():\\n",
   "            means = [scores[probe_type][v]['mean'] for v in pv if scores[probe_type][v]['mean'] is not None]\\n",
   "            result[probe_type] = max(means) - min(means) if len(means) >= 2 else None\\n",
   "        all_results[model_name] = result\\n",
   "        print(f'  DONE {model_name}: {result}')\\n",
   "        del model; gc.collect(); torch.cuda.empty_cache()\\n",
   "\\n",
   "with open('/kaggle/working/new_families_results.json', 'w') as f:\\n",
   "    json.dump(all_results, f, indent=2)\\n",
   "print(f'\\nSaved {len(all_results)} model results to new_families_results.json')\\n"
  ]
 },
