   "---",
   "## Part 2: Attention Analysis at 8B",
   "Tests Format Efficiency Hypothesis on Llama-3-8B base vs instruct.",
   "If format attention decreases (k < 1.0) like at 3B, the hypothesis is confirmed at scale.",
   "---"
  ]
 },
 {
  "cell_type": "code",
  "metadata": null,
  "source": [
   "# ===== ATTENTION ANALYSIS AT Llama-3-8B =====\\n",
   "ATTN_PROMPT = '''Evaluate the following response.\\n",
   "### Instruction: Explain how photosynthesis works.\\n",
   "### Response: Photosynthesis happens in plants where they use sunlight to make food.\\n",
   "### Score from 1-5 (where 1 is worst, 5 is best)\\n",
   "### Score:'''\\n",
   "FORMAT_PATTERNS = ['###', 'Instruction', 'Response', 'Score', '1', '2', '3', '4', '5',\\n",
   "                   'from', 'where', 'is', 'the', 'worst', 'best', ':', '\\\\n', ' ', '.']\\n",
   "CONTENT_PATTERNS = ['photosynthesis', 'explain', 'happens', 'plants', 'sunlight',\\n",
   "                    'food', 'make', 'use', 'they', 'how', 'works']\\n",
   "\\n",
   "def classify_tokens(token_ids, tokenizer):\\n",
   "    labels = []\\n",
   "    for tid in token_ids:\\n",
   "        t = tokenizer.decode(tid).strip().lower()\\n",
   "        if any(f in t for f in FORMAT_PATTERNS): labels.append('FORMAT')\\n",
   "        elif any(c in t for c in CONTENT_PATTERNS): labels.append('CONTENT')\\n",
   "        else: labels.append('OTHER')\\n",
   "    return labels\\n",
   "\\n",
   "ATTN_MODELS = [\\n",
   "    ('meta-llama/Meta-Llama-3-8B', 'Llama-3-8B-base'),\\n",
   "    ('meta-llama/Meta-Llama-3-8B-Instruct', 'Llama-3-8B-instruct'),\\n",
   "]\\n",
   "attn_results = {}\\n",
   "for model_id, name in ATTN_MODELS:\\n",
   "    print(f'\\n=== Loading {name} ===')\\n",
   "    tokenizer = AutoTokenizer.from_pretrained(model_id, token=os.environ['HF_TOKEN'])\\n",
   "    model = AutoModelForCausalLM.from_pretrained(model_id, torch_dtype=torch.float16,\\n",
   "        device_map='auto', output_attentions=True, token=os.environ['HF_TOKEN'])\\n",
   "    model.eval()\\n",
   "    inputs = tokenizer(ATTN_PROMPT, return_tensors='pt').to(model.device)\\n",
   "    labels = classify_tokens(inputs['input_ids'][0].tolist(), tokenizer)\\n",
   "    n_fmt = labels.count('FORMAT'); n_con = labels.count('CONTENT')\\n",
   "    print(f'  Tokens: {len(labels)} total, {n_fmt} format, {n_con} content')\\n",
   "    with torch.no_grad():\\n",
   "        outputs = model(**inputs, output_attentions=True)\\n",
   "    format_attn, content_attn = [], []\\n",
   "    for attn in outputs.attentions:\\n",
   "        last_attn = attn[0].mean(dim=0)[-1, :] * 100\\n",
   "        f_pct = sum(last_attn[i].item() for i in range(len(labels)) if labels[i] == 'FORMAT')\\n",
   "        c_pct = sum(last_attn[i].item() for i in range(len(labels)) if labels[i] == 'CONTENT')\\n",
   "        format_attn.append(f_pct); content_attn.append(c_pct)\\n",
   "    mean_fmt = float(np.mean(format_attn)); mean_con = float(np.mean(content_attn))\\n",
   "    attn_results[name] = {'mean_format_attn': mean_fmt, 'mean_content_attn': mean_con}\\n",
   "    print(f'  Mean format: {mean_fmt:.2f}%  Content: {mean_con:.2f}%')\\n",
   "    del model; gc.collect(); torch.cuda.empty_cache()\\n",
   "\\n",
   "base_a = attn_results.get('Llama-3-8B-base')\\n",
   "instruct_a = attn_results.get('Llama-3-8B-instruct')\\n",
   "if base_a and instruct_a:\\n",
   "    kf = instruct_a['mean_format_attn'] / max(base_a['mean_format_attn'], 0.01)\\n",
   "    kc = instruct_a['mean_content_attn'] / max(base_a['mean_content_attn'], 0.01)\\n",
   "    print(f'\\n{\"=\"*60}\\nFORMAT EFFICIENCY AT 8B\\n{\"=\"*60}')\\n",
   "    print(f'Format k = {kf:.3f}x (IIAR >1.0, Format Efficiency <1.0)')\\n",
   "    print(f'Content k = {kc:.3f}x')\\n",
   "    print(f'\\nPrior: 0.5B k_f=1.003 | 3B k_f=0.879 | 8B k_f={kf:.3f}')\\n",
   "    if kf < 1.0: print('\\n✅ Format Efficiency confirmed at 8B scale')\\n",
   "    else: print('\\n❌ Format Efficiency NOT confirmed at 8B')\\n",
   "\\n",
   "with open('/kaggle/working/attention_results_8b.json', 'w') as f:\\n",
   "    json.dump(attn_results, f, indent=2)\\n",
   "print('\\nSaved attention_results_8b.json')\\n"
  ]
 },
