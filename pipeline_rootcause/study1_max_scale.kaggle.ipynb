 {"cell_type":"code","metadata":{},"source":[
   "# Probe configurations and parsers\\n",
   "PROBES = {\\n",
   "    'rubric_order': {\\n",
   "        'normal': 'Score the following response from 1 to 5 (1=worst, 5=best).',\\n",
   "        'reversed': 'Score the following response from 1 to 5 (1=best, 5=worst).',\\n",
   "        'random': 'Rate the following on a scale where 3=A, 5=B, 1=C, 2=D, 4=E.',\\n",
   "    },\\n",
   "    'score_id': {\\n",
   "        'numeric': 'Score from 1 to 5.',\\n",
   "        'letter': 'Score from A to E (A=best, E=worst).',\\n",
   "        'descriptive': 'Score: Poor, Fair, Good, Very Good, Excellent.',\\n",
   "    },\\n",
   "    'reference_answer': {\\n",
   "        'no_ref': 'Score the following response from 1 to 5.',\\n",
   "        'good_ref': 'Example good answer: AI systems improve through training.\\nNow score the following from 1 to 5.',\\n",
   "        'poor_ref': 'Example poor answer: idk lol.\\nNow score the following from 1 to 5.',\\n",
   "    },\\n",
   "}\\n",
   "\\n",
   "PROBES_TO_RUN = [('rubric_order', ['normal','reversed','random']), ('score_id', ['numeric','letter','descriptive']), ('reference_answer', ['no_ref','good_ref','poor_ref'])]\\n",
   "REPEATS = 3\\n",
   "\\n",
   "def build_prompt(probe_type, variant, item):\\n",
   "    prefix = PROBES[probe_type][variant]\\n",
   "    return f'{prefix}\\n\\n### Instruction:\\n{item[\"instr\"]}\\n\\n### Response:\\n{item[\"resp\"]}\\n\\n### Score:'\\n",
   "\\n",
   "def extract_score(text):\\n",
   "    import re\\n",
   "    match = re.search(r'\\b([1-5])\\b', text)\\n",
   "    return int(match.group(1)) if match else 3\\n",
   "\\n",
   "def extract_letter(text):\\n",
   "    import re\\n",
   "    match = re.search(r'\\b([A-E])\\b', text.upper())\\n",
   "    return {'A':5,'B':4,'C':3,'D':2,'E':1}.get(match.group(1), 3) if match else 3\\n",
   "\\n",
   "def extract_descriptive(text):\\n",
   "    t = text.lower().strip()\\n",
   "    if 'excellent' in t: return 5\\n",
   "    if 'very good' in t: return 4\\n",
   "    if 'good' in t: return 4\\n",
   "    if 'fair' in t: return 3\\n",
   "    if 'poor' in t: return 2\\n",
   "    if 'terrible' in t or 'bad' in t: return 1\\n",
   "    return extract_score(text)\\n",
   "\\n",
   "def get_scorer(probe_type, variant):\\n",
   "    if probe_type == 'score_id':\\n",
   "        if variant == 'letter': return extract_letter\\n",
   "        if variant == 'descriptive': return extract_descriptive\\n",
   "    return extract_score\\n",
   "\\n",
   "CHECKPOINT = '/kaggle/working/checkpoint.json'\\n",
   "print('Probes ready')"
 ]},
 {"cell_type":"code","metadata":{},"source":[
   "# MAIN LOOP: Process all 88 model variants with checkpoints\\n",
   "OUT = '/kaggle/working/study1_max_scale.json'\\n",
   "\\n",
   "# Load checkpoint if exists\\n",
   "all_results = {}\\n",
   "completed = set()\\n",
   "if os.path.exists(CHECKPOINT):\\n",
   "    with open(CHECKPOINT) as f:\\n",
   "        cp = json.load(f)\\n",
   "    all_results = cp.get('results', {})\\n",
   "    completed = set(cp.get('completed', []))\\n",
   "    print(f'Resumed from checkpoint: {len(completed)} models already completed')\\n",
   "\\n",
   "total_models = len(MODELS)\\n",
   "total_start = time.time()\\n",
   "\\n",
   "for idx, (base_id, inst_id, name) in enumerate(MODELS):\\n",
   "    if name in completed:\\n",
   "        print(f'[{idx+1}/{total_models}] {name}: SKIPPED (already done)')\\n",
   "        continue\\n",
   "    \\n",
   "    for variant_type, variant_name in [('base', base_id), ('instruct', inst_id)]:\\n",
   "        full_name = f'{name}_{variant_type}'\\n",
   "        print(f'\\n[{idx+1}/{total_models}] {full_name}')\\n",
   "        print(f'Loading {variant_name}...', end=' ', flush=True)\\n",
   "        t0 = time.time()\\n",
   "        \\n",
   "        try:\\n",
   "            tokenizer = AutoTokenizer.from_pretrained(variant_name, trust_remote_code=True)\\n",
   "            if tokenizer.pad_token is None:\\n",
   "                tokenizer.pad_token = tokenizer.eos_token\\n",
   "            model = AutoModelForCausalLM.from_pretrained(\\n",
   "                variant_name, torch_dtype=torch.float16,\\n",
   "                device_map='auto', trust_remote_code=True,\\n",
   "                low_cpu_mem_usage=True,\\n",
   "            )\\n",
   "            model.eval()\\n",
   "            print(f'OK ({time.time()-t0:.0f}s)')\\n",
   "        except Exception as e:\\n",
   "            print(f'LOAD FAILED: {e}')\\n",
   "            all_results[full_name] = {'error': str(e)}\\n",
   "            continue\\n",
   "        \\n",
   "        # Run probes\\n",
   "        results = {}\\n",
   "        for probe_type, variants in PROBES_TO_RUN:\\n",
   "            print(f'  Probe: {probe_type}', end=' ', flush=True)\\n",
   "            results[probe_type] = {}\\n",
   "            for var_name in variants:\\n",
   "                var_scores = []\\n",
   "                for rep in range(REPEATS):\\n",
   "                    rep_scores = []\\n",
   "                    for item in ITEMS:\\n",
   "                        prompt = build_prompt(probe_type, var_name, item)\\n",
   "                        inputs = tokenizer(prompt, return_tensors='pt', truncation=True, max_length=1024).to(model.device)\\n",
   "                        with torch.no_grad():\\n",
   "                            outputs = model.generate(**inputs, max_new_tokens=3, temperature=0.0, do_sample=False, pad_token_id=tokenizer.pad_token_id)\\n",
   "                        out_text = tokenizer.decode(outputs[0][inputs['input_ids'].shape[1]:], skip_special_tokens=True)\\n",
   "                        rep_scores.append(get_scorer(probe_type, var_name)(out_text))\\n",
   "                    var_scores.append(rep_scores)\\n",
   "                results[probe_type][var_name] = var_scores\\n",
   "            avg = sum(sum(r) for r in var_scores) / (len(var_scores) * len(var_scores[0]))\\n",
   "            print(f'avg={avg:.2f}')\\n",
   "        \\n",
   "        all_results[full_name] = results\\n",
   "        \\n",
   "        # Free memory\\n",
   "        del model, tokenizer\\n",
   "        gc.collect()\\n",
   "        torch.cuda.empty_cache()\\n",
   "        print(f'  Done ({time.time()-t0:.0f}s total)')\\n",
   "    \\n",
   "    # Save checkpoint after each family\\n",
   "    completed.add(name)\\n",
   "    with open(CHECKPOINT, 'w') as f:\\n",
   "        json.dump({'results': all_results, 'completed': list(completed), 'last_update': time.strftime('%Y-%m-%d %H:%M:%S')}, f)\\n",
   "    \\n",
   "    # Progress estimate\\n",
   "    elapsed = time.time() - total_start\\n",
   "    remaining = (elapsed / (idx+1)) * (total_models - idx - 1)\\n",
   "    print(f'  Progress: {idx+1}/{total_models} ({elapsed/3600:.1f}h elapsed, {remaining/3600:.1f}h remaining)')\\n",
   "\\n",
   "# Save final results\\n",
   "with open(OUT, 'w') as f:\\n",
   "    json.dump(all_results, f)\\n",
   "print(f'\\nALL DONE. Results saved to {OUT}')\\n",
   "print(f'Total time: {(time.time()-total_start)/3600:.1f} hours')"
 ]},
 {"cell_type":"code","metadata":{},"source":[
   "# Summary results table\\n",
   "print('\\n' + '='*80)\\n",
   "print('MAXIMUM SCALE EXPERIMENT - SUMMARY')\\n",
   "print('='*80)\\n",
   "print(f\"{'Model':<25} {'Rubric':<10} {'ScoreID':<10} {'RefAns':<10} {'Avg':<10}\")\\n",
   "print('-'*65)\\n",
   "\\n",
   "summary_data = {}\\n",
   "for model_name, results in sorted(all_results.items()):\\n",
   "    if 'error' in results:\\n",
   "        print(f\"{model_name:<25} {'FAILED':<10} {'':<10} {'':<10} {'':<10}\")\\n",
   "        continue\\n",
   "    \\n",
   "    bias_scores = {}\\n",
   "    for probe_type, variants in PROBES_TO_RUN:\\n",
   "        var_means = []\\n",
   "        for var_name in variants:\\n",
   "            if probe_type in results and var_name in results[probe_type] and len(results[probe_type][var_name]) > 0:\\n",
   "                s = sum(sum(r) for r in results[probe_type][var_name]) / sum(len(r) for r in results[probe_type][var_name])\\n",
   "                var_means.append(s)\\n",
   "        if len(var_means) > 1:\\n",
   "            bias_scores[probe_type] = max(abs(var_means[i]-var_means[0]) for i in range(len(var_means)))\\n",
   "    \\n",
   "    rubric = bias_scores.get('rubric_order', -1)\\n",
   "    score = bias_scores.get('score_id', -1)\\n",
